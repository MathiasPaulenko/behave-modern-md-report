root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{py,pyi}]
indent_size = 4

[*.{html,jinja,jinja2}]
indent_size = 2

[*.{css,js,json,md,yml,yaml,ini,toml}]
indent_size = 2

[Makefile]
indent_style = tab
